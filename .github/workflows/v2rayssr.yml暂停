name: V2RaySSR

on:
  workflow_dispatch:

permissions:
  contents: write

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.9'

      - name: Install dependencies
        run: pip install cloudscraper beautifulsoup4

      - name: Scrape and Process
        id: process_data
        run: |
          mkdir -p v2rayssr
          
          cat << 'EOF' > scraper.py
          import cloudscraper
          from bs4 import BeautifulSoup
          import datetime
          import os
          import re
          import ipaddress

          def is_valid_ipv4(ip_str):
              try:
                  return ipaddress.ip_address(ip_str).version == 4
              except ValueError:
                  return False

          def fetch_and_parse():
              scraper = cloudscraper.create_scraper(
                  browser={'browser': 'chrome', 'platform': 'windows', 'desktop': True}
              )
              url = "https://v2rayssr.com/cfip/"
              
              try:
                  res = scraper.get(url, timeout=30)
                  if res.status_code != 200:
                      return False

                  soup = BeautifulSoup(res.text, 'html.parser')
                  table = soup.find('table')
                  if not table:
                      return False

                  rows = table.find_all('tr')
                  new_nodes = []
                  ipv4_pattern = r'(?:25[0-5]|2[0-4]\d|[01]?\d\d?)\.(?:25[0-5]|2[0-4]\d|[01]?\d\d?)\.(?:25[0-5]|2[0-4]\d|[01]?\d\d?)\.(?:25[0-5]|2[0-4]\d|[01]?\d\d?)'

                  for row in rows:
                      cols = row.find_all('td')
                      if len(cols) >= 6:
                          line = cols[1].get_text(strip=True)
                          if "IPv6" in line.upper():
                              continue
                          
                          row_html = str(row)
                          found_ips = re.findall(ipv4_pattern, row_html)
                          
                          valid_ip = None
                          for candidate in found_ips:
                              if is_valid_ipv4(candidate):
                                  valid_ip = candidate
                                  break
                          
                          if not valid_ip:
                              continue

                          latency = cols[4].get_text(strip=True)
                          speed = cols[5].get_text(strip=True)
                          
                          formatted = f"{valid_ip}:443#{line} | {valid_ip} | {latency} | {speed}"
                          new_nodes.append(formatted)

                  output_path = os.path.join("v2rayssr", "all.txt")
                  old_nodes = []
                  if os.path.exists(output_path):
                      with open(output_path, "r", encoding="utf-8") as f:
                          lines = f.readlines()
                          if len(lines) > 2:
                              old_nodes = [l.strip() for l in lines[1:-1]]

                  if new_nodes == old_nodes:
                      print("内容未发生变化，跳过更新。")
                      return False

                  bj_time = (datetime.datetime.utcnow() + datetime.timedelta(hours=8)).strftime('%m-%d %H:%M')
                  header = f"saas.sin.fan:443#▼ V2RaySSR优选IP | {bj_time} | YouTube@真香定律"
                  footer = "bestcf.030101.xyz:443#▲ V2RaySSR优选IP | 分享免费优选网 Bestcf.pages.dev"

                  with open(output_path, "w", encoding="utf-8") as f:
                      f.write(header + "\n")
                      for node in new_nodes:
                          f.write(node + "\n")
                      f.write(footer + "\n")
                  
                  print(f"成功抓取 {len(new_nodes)} 条新数据。")
                  return True

              except Exception as e:
                  print(f"Error: {e}")
                  return False

          if __name__ == "__main__":
              changed = fetch_and_parse()
              with open(os.environ['GITHUB_OUTPUT'], 'a') as fh:
                  print(f"changed={str(changed).lower()}", file=fh)
          EOF
          python scraper.py

      - name: Commit and Push
        if: steps.process_data.outputs.changed == 'true'
        run: |
          git config --local user.email "actions@github.com"
          git config --local user.name "GitHub Action"
          git add v2rayssr/all.txt
          git commit -m "v2rayssr $(date +'%Y-%m-%d %H:%M')"
          git push